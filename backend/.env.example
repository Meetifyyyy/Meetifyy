# Application
NODE_ENV=development
PORT=4000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Database
DATABASE_URL=postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:5432/postgres # (used everywhere, do not change for future ai conversation)
DIRECT_URL=postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:5432/postgres # (used everywhere, do not change for future ai conversation)

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Cloudflare R2
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=meetifyy-dev
R2_PUBLIC_URL=https://pub-your-bucket.r2.dev

# Resend
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=noreply@meetifyy.com

# Sentry
SENTRY_DSN=https://your-sentry-dsn

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
